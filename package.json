{
  "name": "agiliza-ai-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "lefthook install"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#features/*": "./app/features/*.js",
    "#shared/*": "./app/shared/*.js",
    "#jobs/*": "./app/jobs/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.0",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@japa/assert": "^4.2.0",
    "@japa/plugin-adonisjs": "^5.1.0",
    "@japa/runner": "^5.3.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "~24.11.0",
    "eslint": "^10.0.2",
    "hot-hook": "^1.0.0",
    "lefthook": "^2.1.4",
    "luxon": "^3.7.2",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "youch": "^4.1.0"
  },
  "dependencies": {
    "@adonisjs/auth": "^10.0.0",
    "@adonisjs/core": "^7.0.0",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/drive": "^4.0.0",
    "@adonisjs/limiter": "^3.0.1",
    "@adonisjs/lucid": "^22.0.0",
    "@adonisjs/queue": "^0.6.0",
    "@adonisjs/redis": "^10.0.0",
    "@japa/api-client": "^3.2.1",
    "@vinejs/vine": "^4.3.0",
    "geolib": "^3.3.4",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "uuidv7": "^1.0.2"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  }
}
